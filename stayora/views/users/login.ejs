<%-layout("/layouts/boilerplate")%>
<body>
    <br>
    <div class="row">
        <div class="col-6 offset-3">
            <h1>Login</h1>
            <form action="/login" method="post" novalidate class="needs-validation">
                <div class="mb-3">
                    <label for="username" class="form-label">Username</label>
                    <input type="text" class="form-control" placeholder="Enter Username" name="username" id="username" required>
                </div>
                <div class="mb-3">
                    <label for="password" class="form-label">Password</label>
                    <input type="password" class="form-control" placeholder="Enter Password" name="password" id="password" required>
                </div>
                <button class="btn btn-dark login-btn">Login</button>
            </form>
        </div>
    </div>
</body>